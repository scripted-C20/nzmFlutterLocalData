  double _twoColumnCardWidth(double maxWidth, {double spacing = 10}) {
    final double width = (maxWidth - spacing) / 2;
    if (width < 140) {
      return maxWidth;
    }
    return width;
  }

  Widget _buildEqualHeightTwoColumnRows<T>({
    required List<T> items,
    required Widget Function(T item) itemBuilder,
    double spacing = 10,
  }) {
    final List<Widget> rows = <Widget>[];
    for (int i = 0; i < items.length; i += 2) {
      final T first = items[i];
      final T? second = i + 1 < items.length ? items[i + 1] : null;
      rows.add(
        Padding(
          padding: EdgeInsets.only(bottom: i + 2 < items.length ? spacing : 0),
          child: IntrinsicHeight(
            child: Row(
              crossAxisAlignment: CrossAxisAlignment.stretch,
              children: <Widget>[
                Expanded(child: itemBuilder(first)),
                SizedBox(width: spacing),
                Expanded(
                  child: second == null
                      ? const SizedBox.shrink()
                      : itemBuilder(second),
                ),
              ],
            ),
          ),
        ),
      );
    }
    return Column(children: rows);
  }

  String _safeString(String Function() getter, [String fallback = ""]) {
    try {
      final String value = getter();
      final String text = value.trim();
      if (text.isEmpty || text.toLowerCase() == "null") {
        return fallback;
      }
      return text;
    } catch (_) {
      return fallback;
    }
  }

  int _safeInt(int Function() getter, [int fallback = 0]) {
    try {
      return getter();
    } catch (_) {
      return fallback;
    }
  }

  double _safeDouble(double Function() getter, [double fallback = 0]) {
    try {
      return getter();
    } catch (_) {
      return fallback;
    }
  }
}

