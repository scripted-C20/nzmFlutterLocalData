class NzmHomePage extends StatefulWidget {
  const NzmHomePage({super.key});

  @override
  State<NzmHomePage> createState() => _NzmHomePageState();
}

class _NzmHomePageState extends State<NzmHomePage> {
  late final AppController _controller;
  static const String _noticeUrl =
      "https://gitee.com/returnee/nzm-notice/raw/master/Flutter_README.md";

  @override
  void initState() {
    super.initState();
    _controller = AppController()..init();
  }

  @override
  void dispose() {
    _controller.dispose();
    super.dispose();
  }

  Future<String> _loadNoticeMarkdown() async {
    final Uri uri = Uri.parse(_noticeUrl);
    final http.Response response = await http.get(
      uri,
      headers: const <String, String>{
        "Accept": "text/markdown,text/plain,*/*",
      },
    );
    if (response.statusCode < 200 || response.statusCode >= 300) {
      throw Exception("公告拉取失败（HTTP ${response.statusCode}）");
    }
    if (response.bodyBytes.isEmpty) {
      throw Exception("鍏憡鍐呭涓虹┖");
    }
    return utf8.decode(response.bodyBytes, allowMalformed: true);
  }

  Future<void> _openNoticeDialog() async {
    if (!mounted) return;
    await showDialog<void>(
      context: context,
      builder: (BuildContext dialogContext) {
        return AlertDialog(
          title: const Text("鍏憡"),
          content: SizedBox(
            width: 680,
            height: MediaQuery.of(dialogContext).size.height * 0.66,
            child: FutureBuilder<String>(
              future: _loadNoticeMarkdown(),
              builder: (BuildContext context, AsyncSnapshot<String> snapshot) {
                if (snapshot.connectionState != ConnectionState.done) {
                  return const Center(child: CircularProgressIndicator());
                }
                if (snapshot.hasError) {
                  return SingleChildScrollView(
                    child: Text(
                      "鍏憡鍔犺浇澶辫触锛?{snapshot.error}",
                      style: const TextStyle(color: NzmTheme.red),
                    ),
                  );
                }
                final String markdownText = snapshot.data ?? "";
                return Scrollbar(
                  child: SingleChildScrollView(
                    padding: const EdgeInsets.only(right: 4),
                    child: MarkdownBody(
                      data: markdownText,
                      selectable: true,
                    ),
                  ),
                );
              },
            ),
          ),
          actions: <Widget>[
            TextButton(
              onPressed: () => Navigator.of(dialogContext).pop(),
              child: const Text("鍏抽棴"),
            ),
          ],
        );
      },
    );
  }

  @override
  Widget build(BuildContext context) {
    return AnimatedBuilder(
      animation: _controller,
      builder: (BuildContext context, _) {
        return NzmBackground(
          child: Scaffold(
            appBar: AppBar(
              title: const Text("NZM 鏁版嵁缁熻"),
              actions: <Widget>[
                IconButton(
                  tooltip: "鍏憡",
                  onPressed: _openNoticeDialog,
                  icon: const Icon(Icons.campaign_outlined),
                ),
                IconButton(
                  tooltip: "鍒锋柊鏁版嵁",
                  onPressed: _controller.isLoading
                      ? null
                      : () => _controller.refreshAllData(showLoading: true),
                  icon: const Icon(Icons.refresh),
                ),
              ],
            ),
            body: Column(
              children: <Widget>[
                NzmStatusBar(
                  message: _controller.statusMessage,
                  showLoading: _controller.isRefreshingData,
                ),
                Expanded(
                  child: Padding(
                    padding: const EdgeInsets.all(12),
                    child: _buildTabBody(),
                  ),
                ),
                if (_controller.isLoading && !_controller.isRefreshingData)
                  const LinearProgressIndicator(minHeight: 2),
              ],
            ),
            bottomNavigationBar: NavigationBar(
              selectedIndex: _controller.rootTab.index,
              onDestinationSelected: (int index) {
                _controller.setRootTab(RootTab.values[index]);
              },
              destinations: const <NavigationDestination>[
                NavigationDestination(
                  icon: Icon(Icons.analytics_outlined),
                  selectedIcon: Icon(Icons.analytics),
                  label: "鏁版嵁缁熻",
                ),
                NavigationDestination(
                  icon: Icon(Icons.history_toggle_off),
                  selectedIcon: Icon(Icons.history),
                  label: "鍘嗗彶鎴樼哗",
                ),
                NavigationDestination(
                  icon: Icon(Icons.folder_copy_outlined),
                  selectedIcon: Icon(Icons.folder_copy),
                  label: "鏈湴鎴樼哗",
                ),
                NavigationDestination(
                  icon: Icon(Icons.person_outline),
                  selectedIcon: Icon(Icons.person),
                  label: "璐﹀彿绠＄悊",
                ),
              ],
            ),
          ),
        );
      },
    );
  }

  Widget _buildTabBody() {
    switch (_controller.rootTab) {
      case RootTab.stats:
        return StatsTab(controller: _controller);
      case RootTab.history:
        return HistoryTab(controller: _controller);
      case RootTab.local:
        return LocalTab(controller: _controller);
      case RootTab.profile:
        return ProfileTab(controller: _controller);
      case RootTab.logs:
        return const LogTab();
    }
  }
}

