class QiniuConfigDialog extends StatefulWidget {
  const QiniuConfigDialog({required this.controller, super.key});

  final AppController controller;

  @override
  State<QiniuConfigDialog> createState() => _QiniuConfigDialogState();
}

class _QiniuConfigDialogState extends State<QiniuConfigDialog> {
  late final TextEditingController _accessKey;
  late final TextEditingController _secretKey;
  late final TextEditingController _domain;
  late final TextEditingController _bucket;
  late final TextEditingController _path;
  late String _protocol;

  @override
  void initState() {
    super.initState();
    final QiniuConfig q = widget.controller.qiniuConfig;
    _accessKey = TextEditingController(text: q.accessKey);
    _secretKey = TextEditingController(text: q.secretKey);
    _domain = TextEditingController(text: q.domain);
    _bucket = TextEditingController(text: q.bucket);
    _path = TextEditingController(text: q.path);
    _protocol = q.protocol.trim().toLowerCase() == "http" ? "http" : "https";
  }

  @override
  void dispose() {
    _accessKey.dispose();
    _secretKey.dispose();
    _domain.dispose();
    _bucket.dispose();
    _path.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return AlertDialog(
      title: const Text("七牛云配置"),
      content: SizedBox(
        width: 520,
        child: SingleChildScrollView(
          child: Column(
            mainAxisSize: MainAxisSize.min,
            crossAxisAlignment: CrossAxisAlignment.start,
            children: <Widget>[
              const Text(
                "填写后可将本地统计上传到云端，并支持从云端拉取。",
                style: TextStyle(fontSize: 12, color: NzmTheme.muted),
              ),
              const SizedBox(height: 8),
              TextField(
                controller: _accessKey,
                decoration: const InputDecoration(
                  labelText: "AccessKey",
                  hintText: "渚嬪锛氫綘鐨?AccessKey",
                ),
              ),
              const SizedBox(height: 8),
              TextField(
                controller: _secretKey,
                decoration: const InputDecoration(
                  labelText: "SecretKey",
                  hintText: "渚嬪锛氫綘鐨?SecretKey",
                ),
              ),
              const SizedBox(height: 8),
              DropdownButtonFormField<String>(
                initialValue: _protocol,
                decoration: const InputDecoration(labelText: "鍗忚"),
                items: const <DropdownMenuItem<String>>[
                  DropdownMenuItem<String>(
                      value: "https", child: Text("https")),
                  DropdownMenuItem<String>(value: "http", child: Text("http")),
                ],
                onChanged: (String? value) {
                  if (value == null) return;
                  setState(() {
                    _protocol = value;
                  });
                },
              ),
              const SizedBox(height: 8),
              TextField(
                controller: _domain,
                decoration: const InputDecoration(
                  labelText: "鍩熷悕",
                  hintText: "渚嬪锛歝dn.example.com",
                ),
              ),
              const SizedBox(height: 8),
              TextField(
                controller: _bucket,
                decoration: const InputDecoration(
                  labelText: "瀛樺偍绌洪棿鍚嶇О",
                  hintText: "渚嬪锛歜ucket 鍚嶇О",
                ),
              ),
              const SizedBox(height: 8),
              TextField(
                controller: _path,
                decoration: const InputDecoration(
                  labelText: "淇濆瓨璺緞",
                  hintText: "渚嬪锛歯zm/local-stats",
                ),
              ),
            ],
          ),
        ),
      ),
      actions: <Widget>[
        TextButton(
          onPressed: () => Navigator.of(context).pop(),
          child: const Text("鍙栨秷"),
        ),
        FilledButton(
          onPressed: () async {
            final NavigatorState navigator = Navigator.of(context);
            await widget.controller.saveQiniuConfig(
              QiniuConfig(
                accessKey: _accessKey.text.trim(),
                secretKey: _secretKey.text.trim(),
                protocol: _protocol,
                domain: _domain.text.trim(),
                path: _path.text.trim(),
                bucket: _bucket.text.trim(),
                updatedAt: DateTime.now().millisecondsSinceEpoch,
              ),
            );
            if (!mounted) return;
            navigator.pop();
          },
          child: const Text("淇濆瓨閰嶇疆"),
        ),
      ],
    );
  }
}

class MatchDetailPanel extends StatelessWidget {
  const MatchDetailPanel(
      {required this.controller, required this.roomId, super.key});

  final AppController controller;
  final String roomId;

  @override
  Widget build(BuildContext context) {
    if (controller.isDetailLoading(roomId)) {
      return const LinearProgressIndicator(minHeight: 2);
    }
    final String? err = controller.detailErrorByRoomId(roomId);
    if (err != null && err.isNotEmpty) {
      return Text("璇︽儏鍔犺浇澶辫触锛?err");
    }
    final MatchDetailData? detail = controller.detailByRoomId(roomId);
    if (detail == null || detail.players.isEmpty) {
      return const Text("鏆傛棤璇︽儏鏁版嵁");
    }
    final MatchPlayerDetail primary = _pickPrimary(detail.players);
    final List<MatchPlayerDetail> orderedPlayers =
        List<MatchPlayerDetail>.from(detail.players)
          ..sort((MatchPlayerDetail a, MatchPlayerDetail b) {
            if (a.isSelf == b.isSelf) return 0;
            return a.isSelf ? -1 : 1;
          });
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: <Widget>[
        _partitionRow(primary.partitionDetails),
        const SizedBox(height: 8),
        ...orderedPlayers.map((MatchPlayerDetail player) {
          return Padding(
            padding: const EdgeInsets.only(bottom: 8),
            child: Container(
              width: double.infinity,
              padding: const EdgeInsets.all(8),
              decoration: BoxDecoration(
                color: const Color(0xAA132843),
                borderRadius: BorderRadius.circular(8),
                border: Border.all(
                    color: player.isSelf ? NzmTheme.green : NzmTheme.line),
              ),
              child: Column(
                crossAxisAlignment: CrossAxisAlignment.start,
                children: <Widget>[
                  Text(
                    "${player.nickname}${player.isSelf ? " (浣?" : ""}",
                    style: const TextStyle(
                        fontWeight: FontWeight.w700, fontSize: 12),
                  ),
                  const SizedBox(height: 6),
                  _huntingMetrics(player),
                  const SizedBox(height: 6),
                  _equipmentSection(player.equipments),
                ],
              ),
            ),
          );
        }),
      ],
    );
  }

  MatchPlayerDetail _pickPrimary(List<MatchPlayerDetail> players) {
    for (final MatchPlayerDetail p in players) {
      if (p.isSelf) return p;
    }
    for (final MatchPlayerDetail p in players) {
      if (p.partitionDetails.isNotEmpty) return p;
    }
    for (final MatchPlayerDetail p in players) {
      if (p.equipments.isNotEmpty) return p;
    }
    final List<MatchPlayerDetail> sorted = List<MatchPlayerDetail>.from(players)
      ..sort((MatchPlayerDetail a, MatchPlayerDetail b) =>
          b.bossDamage.compareTo(a.bossDamage));
    return sorted.first;
  }

  Widget _huntingMetrics(MatchPlayerDetail detail) {
    Widget metric(String label, int value) {
      return Container(
        padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 7),
        decoration: BoxDecoration(
          color: const Color(0xAA132843),
          borderRadius: BorderRadius.circular(8),
          border: Border.all(color: NzmTheme.line),
        ),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: <Widget>[
            Text(label,
                style: const TextStyle(fontSize: 9, color: NzmTheme.muted)),
            const SizedBox(height: 1),
            Text(
              _formatNumber(value),
              style: const TextStyle(fontSize: 12, fontWeight: FontWeight.w700),
            ),
          ],
        ),
      );
    }

    Widget gap() => const SizedBox(width: 6);

    return Column(
      children: <Widget>[
        Row(
          children: <Widget>[
            Expanded(child: metric("绉垎", detail.score)),
            gap(),
            Expanded(child: metric("鍑绘潃", detail.kills)),
            gap(),
            Expanded(child: metric("姝讳骸", detail.deaths)),
          ],
        ),
        const SizedBox(height: 6),
        Row(
          children: <Widget>[
            Expanded(child: metric("Boss浼ゅ", detail.bossDamage)),
            gap(),
            Expanded(child: metric("小怪伤害", detail.mobsDamage)),
            gap(),
            Expanded(child: metric("閲戝竵", detail.totalCoin)),
          ],
        ),
      ],
    );
  }

  Widget _partitionRow(List<MatchPartitionDetail> list) {
    if (list.isEmpty) {
      return Container(
        width: double.infinity,
        padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 8),
        decoration: BoxDecoration(
          color: const Color(0xAA132843),
          borderRadius: BorderRadius.circular(8),
          border: Border.all(color: NzmTheme.line),
        ),
        child: const Text("鏆傛棤鍖哄煙鐢ㄦ椂鏁版嵁"),
      );
    }
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: <Widget>[
        const Text("鍖哄煙鐢ㄦ椂",
            style: TextStyle(fontWeight: FontWeight.w700, fontSize: 12)),
        const SizedBox(height: 6),
        SingleChildScrollView(
          scrollDirection: Axis.horizontal,
          child: Row(
            children: list.map((MatchPartitionDetail e) {
              return Container(
                width: 122,
                margin: const EdgeInsets.only(right: 8),
                padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 8),
                decoration: BoxDecoration(
                  color: const Color(0xAA132843),
                  borderRadius: BorderRadius.circular(8),
                  border: Border.all(color: NzmTheme.line),
                ),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: <Widget>[
                    Text(
                      e.areaName,
                      maxLines: 1,
                      overflow: TextOverflow.ellipsis,
                      style: const TextStyle(
                        color: NzmTheme.green,
                        fontSize: 13,
                        fontWeight: FontWeight.w700,
                      ),
                    ),
                    const SizedBox(height: 4),
                    Text(
                      _formatDuration(e.usedTime),
                      style: const TextStyle(
                        fontSize: 13,
                        fontWeight: FontWeight.w800,
                      ),
                    ),
                  ],
                ),
              );
            }).toList(),
          ),
        ),
      ],
    );
  }

  Widget _equipmentSection(List<MatchEquipment> equipments) {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: <Widget>[
        const Text("鏈眬瑁呴厤",
            style: TextStyle(fontWeight: FontWeight.w700, fontSize: 12)),
        const SizedBox(height: 6),
        if (equipments.isEmpty)
          const Text("鏆傛棤瑁呴厤鏁版嵁", style: TextStyle(fontSize: 11))
        else
          SingleChildScrollView(
            scrollDirection: Axis.horizontal,
            child: Row(
              children: equipments.map((MatchEquipment e) {
                return Container(
                  width: 170,
                  margin: const EdgeInsets.only(right: 8),
                  padding: const EdgeInsets.all(8),
                  decoration: BoxDecoration(
                    color: const Color(0xAA132843),
                    borderRadius: BorderRadius.circular(8),
                    border: Border.all(color: NzmTheme.line),
                  ),
                  child: Row(
                    children: <Widget>[
                      if (e.iconUrl.trim().isNotEmpty)
                        ClipRRect(
                          borderRadius: BorderRadius.circular(4),
                          child: Image.network(
                            e.iconUrl,
                            width: 24,
                            height: 24,
                            fit: BoxFit.cover,
                            errorBuilder: (
                              BuildContext _,
                              Object __,
                              StackTrace? ___,
                            ) =>
                                const SizedBox(width: 24, height: 24),
                          ),
                        ),
                      const SizedBox(width: 6),
                      Expanded(
                        child: Column(
                          crossAxisAlignment: CrossAxisAlignment.start,
                          children: <Widget>[
                            Text(
                              e.name,
                              maxLines: 1,
                              overflow: TextOverflow.ellipsis,
                              style: const TextStyle(
                                  fontWeight: FontWeight.w700, fontSize: 11),
                            ),
                            Text(
                              e.commonItems.isEmpty
                                  ? "无词条"
                                  : e.commonItems
                                      .map((MatchCommonItem i) => i.name)
                                      .join("/"),
                              maxLines: 1,
                              overflow: TextOverflow.ellipsis,
                              style: const TextStyle(
                                  fontSize: 9, color: NzmTheme.muted),
                            ),
                          ],
                        ),
                      ),
                    ],
                  ),
                );
              }).toList(),
            ),
          ),
      ],
    );
  }

  String _formatDuration(int seconds) {
    final int value = seconds < 0 ? 0 : seconds;
    final int m = value ~/ 60;
    final int s = value % 60;
    return "$m分${s.toString().padLeft(2, "0")}秒";
  }

  String _formatNumber(int value) {
    final String raw = value.toString();
    return raw.replaceAllMapped(
      RegExp(r"\B(?=(\d{3})+(?!\d))"),
      (Match _) => ",",
    );
  }
}
