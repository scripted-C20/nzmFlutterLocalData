          NzmEmptyState(c.hasBoundAccount
              ? (c.lastRefreshUnauthorized
                  ? "历史战绩拉取失败：账号授权失效，请在账号页更新 token 后重试"
                  : "鏆傛棤鍘嗗彶鎴樼哗")
              : "璇峰厛缁戝畾璐﹀彿"),
      ],
    );
  }

  Widget _recordCard(AppController c, BattleRecord e) {
    final String key = c.recordIdentityKey(e);
    final bool open = _expanded.contains(key);
    final String resultText = e.isWin ? "鑳滃埄" : "澶辫触";
    final String durationText = _formatDuration(e.durationSeconds);
    final String damageText = e.score > 0 ? _formatNumber(e.score) : "--";
    final BattleRemark? remark = c.remarkForRecord(e);
    return NzmPanelCard(
      child: Column(
        children: <Widget>[
          ListTile(
            dense: true,
            contentPadding: EdgeInsets.zero,
            title: Row(
              children: <Widget>[
                Expanded(child: Text("$resultText | ${e.modeName}")),
                const SizedBox(width: 8),
                Text(
                  damageText,
                  style: const TextStyle(
                    fontSize: 13,
                    color: Color(0xFFFF6B6B),
                    fontWeight: FontWeight.w700,
                  ),
                ),
              ],
            ),
            subtitle: Text(
              "${e.mapName} | ${e.difficultyName} | ${e.timeText} | $durationText",
              style: const TextStyle(fontSize: 11),
            ),
            trailing: Icon(open ? Icons.expand_less : Icons.expand_more),
            onTap: () {
              setState(() {
                if (open) {
                  _expanded.remove(key);
                } else {
                  _expanded.add(key);
                }
              });
              if (!open && e.roomId.trim().isNotEmpty) {
                c.loadMatchDetail(e.roomId);
              }
            },
          ),
          if (remark != null && remark.text.trim().isNotEmpty)
            Padding(
              padding: const EdgeInsets.only(bottom: 6),
              child: Align(
                alignment: Alignment.centerLeft,
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: <Widget>[
                    Text(
                      "第 ${remark.modeNth > 0 ? remark.modeNth : 1} 次备注",
                      style: const TextStyle(
                        fontSize: 11,
                        color: NzmTheme.muted,
                      ),
                    ),
                    Text(
                      "澶囨敞锛?{remark.text}",
                      maxLines: 2,
                      overflow: TextOverflow.ellipsis,
                      style: const TextStyle(
                        fontSize: 12,
                        color: NzmTheme.green,
                      ),
                    ),
                  ],
                ),
              ),
            ),
          if (open) MatchDetailPanel(controller: c, roomId: e.roomId),
        ],
      ),
    );
  }

  String _formatDuration(int seconds) {
    final int value = seconds < 0 ? 0 : seconds;
    final int m = value ~/ 60;
    final int s = value % 60;
    return "$m分${s.toString().padLeft(2, "0")}秒";
  }

  String _formatNumber(int value) {
    final String raw = value.toString();
    return raw.replaceAllMapped(
      RegExp(r"\B(?=(\d{3})+(?!\d))"),
      (Match _) => ",",
    );
  }
}

Future<void> _showRemarkEditorDialog({
  required BuildContext context,
  required AppController controller,
