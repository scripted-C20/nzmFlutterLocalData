  });

  final LocalStatsData data;
  final int remarkCount;
  final List<MapStatsEntry> statsMapStats;

  @override
  Widget build(BuildContext context) {
    final int officialCount = (data.totalRecords - data.manualRows) < 0
        ? 0
        : (data.totalRecords - data.manualRows);
    final Map<String, String> iconByMapName = <String, String>{};
    for (final MapStatsEntry entry in statsMapStats) {
      final String key = entry.mapName.trim();
      final String icon = entry.iconUrl.trim();
      if (key.isEmpty || icon.isEmpty) continue;
      iconByMapName.putIfAbsent(key, () => icon);
    }
    return Column(
      children: <Widget>[
        NzmPanelCard(
          child: Wrap(
            spacing: 10,
            runSpacing: 10,
            children: <Widget>[
              NzmMetricCard(
                  label: "鏈湴璁板綍鍦烘暟",
                  value: nzmFormatNumber(data.totalRecords)),
              NzmMetricCard(
                  label: "瀵煎叆鍦烘暟", value: nzmFormatNumber(data.manualRows)),
              NzmMetricCard(
                  label: "瀹樻柟鍚屾鍦烘暟", value: nzmFormatNumber(officialCount)),
              NzmMetricCard(
                  label: "澶囨敞鏉℃暟", value: nzmFormatNumber(remarkCount)),
            ],
          ),
        ),
        NzmPanelCard(
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: <Widget>[
              const NzmSectionTitle("杩戞湡鍦板浘璇︽儏"),
              if (data.mapStats.isEmpty) const Text("鏆傛棤鏁版嵁"),
              if (data.mapStats.isNotEmpty)
                LayoutBuilder(
                  builder: (BuildContext context, BoxConstraints constraints) {
                    final double cardWidth = _localMapCardWidth(
                      constraints.maxWidth,
                    );
                    return Wrap(
                      spacing: 10,
                      runSpacing: 10,
                      children: data.mapStats.take(12).map((MapStatsEntry e) {
                        return SizedBox(
                          width: cardWidth,
                          child: _buildLocalMapCard(
                            e,
                            fallbackIconByMapName: iconByMapName,
                          ),
                        );
                      }).toList(),
                    );
                  },
                ),
            ],
          ),
        ),
      ],
    );
  }

  double _localMapCardWidth(double maxWidth, {double spacing = 10}) {
    final double width = (maxWidth - spacing) / 2;
    if (width < 140) {
      return maxWidth;
    }
    return width;
  }

  Widget _buildLocalMapCard(
    MapStatsEntry e, {
    required Map<String, String> fallbackIconByMapName,
  }) {
    final String iconUrl = e.iconUrl.trim().isNotEmpty
        ? e.iconUrl.trim()
        : (fallbackIconByMapName[e.mapName.trim()] ?? "");
    final bool hasBg = iconUrl.isNotEmpty;
    return Container(
      decoration: BoxDecoration(
        borderRadius: BorderRadius.circular(8),
        border: Border.all(color: NzmTheme.line),
        image: hasBg
            ? DecorationImage(
                image: NetworkImage(iconUrl),
                fit: BoxFit.cover,
                onError: (Object _, StackTrace? __) {},
              )
            : null,
        color: hasBg ? null : const Color(0xAA132843),
      ),
      child: Container(
        padding: const EdgeInsets.all(8),
        decoration: BoxDecoration(
          borderRadius: BorderRadius.circular(8),
          gradient: const LinearGradient(
            begin: Alignment.topCenter,
            end: Alignment.bottomCenter,
            colors: <Color>[Color(0x22000000), Color(0xCC020812)],
          ),
        ),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: <Widget>[
            Text(
              e.mapName,
              maxLines: 1,
              overflow: TextOverflow.ellipsis,
              style: const TextStyle(fontSize: 15, fontWeight: FontWeight.w700),
            ),
            const SizedBox(height: 4),
            Text(
              "${nzmFormatNumber(e.games)} 鍦?- ${e.winRate.toStringAsFixed(1)}% 鑳滅巼",
              style: const TextStyle(fontSize: 12),
            ),
            ...e.difficulties.take(3).map((MapDifficultyEntry d) {
              return Padding(
                padding: const EdgeInsets.only(top: 3),
                child: Text(
                  "${d.diffName}锛?{nzmFormatNumber(d.games)} 鍦?(${d.winRate.toStringAsFixed(1)}%)",
                  maxLines: 1,
                  overflow: TextOverflow.ellipsis,
                  style: const TextStyle(fontSize: 11, color: NzmTheme.muted),
                ),
              );
            }),
          ],
        ),
      ),
    );
  }
}

